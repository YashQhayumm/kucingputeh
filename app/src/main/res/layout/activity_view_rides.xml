<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="             Available Rides"
            android:textColor="#212121"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRefreshRides"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="Refresh"
            android:backgroundTint="#061369"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnGoToBookings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Bookings"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <EditText
        android:id="@+id/etSearchDestination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search by origin or destination"
        android:inputType="text"
        android:padding="10dp"
        android:layout_marginBottom="12dp"
        android:background="#F0F0F0"/>

    <TextView
        android:id="@+id/tvEmptyRides"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No rides available right now."
        android:textColor="#757575"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRides"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>