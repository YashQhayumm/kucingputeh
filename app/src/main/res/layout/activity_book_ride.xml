<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Book Your Ride"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="32dp"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selected Ride Info:"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvSelectedRide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Melaka Sentral ➔ KL Sentral\nDeparture: 2026-07-01 09:30:00"
        android:background="#F0F0F0"
        android:padding="12dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Number of Seats:"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnViewOnMap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Pickup &amp; Destination on Map"
        android:backgroundTint="#00897B"
        android:textColor="@android:color/white"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/etSeats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter number of seats (e.g. 2)"
        android:inputType="number"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm Booking Slot"
        android:backgroundTint="#4CAF50"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

</LinearLayout>